'use strict';
require('dotenv').config({ path: '/root/zeus-terminal/.env' });
const jwt = require('jsonwebtoken');
const db = require('/root/zeus-terminal/server/services/database');

const admin = db.findUserByEmail('wsov2@protonmail.com');
const all = db.listUsers();
const user = all.find((u) => u.id !== admin.id);

if (!admin) { console.error('admin not found'); process.exit(1); }

const adminTok = jwt.sign({ id: admin.id, email: admin.email, role: admin.role }, process.env.JWT_SECRET, { expiresIn: '1h' });
const userTok = user ? jwt.sign({ id: user.id, email: user.email, role: user.role }, process.env.JWT_SECRET, { expiresIn: '1h' }) : null;

console.log('ADMIN_ID=' + admin.id);
console.log('ADMIN_EMAIL=' + admin.email);
console.log('ADMIN_ROLE=' + admin.role);
console.log('ADMIN_TOKEN=' + adminTok);
if (user) {
  console.log('USER_ID=' + user.id);
  console.log('USER_EMAIL=' + user.email);
  console.log('USER_ROLE=' + user.role);
  console.log('USER_TOKEN=' + userTok);
} else {
  console.log('USER_TOKEN=NONE');
}
