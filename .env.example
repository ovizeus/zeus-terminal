# Zeus Terminal — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Binance Futures API ───
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Binance Endpoint ───
# Testnet: https://testnet.binancefuture.com
# Mainnet: https://fapi.binance.com
BINANCE_BASE_URL=https://testnet.binancefuture.com

# ─── Risk Limits (server-enforced) ───
MAX_LEVERAGE=10
MAX_POSITION_USDT=100
DAILY_LOSS_LIMIT_PCT=5

# ─── Master Kill Switch ───
# Set to false to block ALL order routes
TRADING_ENABLED=false

# ─── Auth Token ───
# Shared secret for /api/* routes (set a strong random string)
TRADING_TOKEN=

# ─── Server ───
PORT=3000

# ─── Telegram Alerts ───
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sync Token (PC <-> Phone state sync auth) ───
# Set a strong random string. If empty, default 'zeus-sync-2024' is used (INSECURE)
SYNC_TOKEN=

# ─── Email / SMTP (REQUIRED for 2FA codes) ───
# Gmail: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Security Secrets (REQUIRED — server won't start without these) ───
JWT_SECRET=
ENCRYPTION_KEY=

# ─── Server AT (Phase 6 live execution) ───
# User ID whose exchange credentials will be used for server-side trading
SERVER_AT_USER_ID=1

# ─── Server Data Feed (Phase 2) ───
# Symbol and timeframes for server-side brain
SD_SYMBOL=BTCUSDT
SD_TIMEFRAMES=5m,1h,4h

# ─── Environment ───
NODE_ENV=production

# ─── IP Whitelist (comma-separated, empty = allow all) ───
ALLOWED_IPS=
