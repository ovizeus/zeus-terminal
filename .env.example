# Zeus Terminal — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Binance Futures API ───
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Binance Endpoint ───
# Testnet: https://testnet.binancefuture.com
# Mainnet: https://fapi.binance.com
BINANCE_BASE_URL=https://testnet.binancefuture.com

# ─── Risk Limits (server-enforced) ───
MAX_LEVERAGE=10
MAX_POSITION_USDT=100
DAILY_LOSS_LIMIT_PCT=5

# ─── Master Kill Switch ───
# Set to false to block ALL order routes
TRADING_ENABLED=false

# ─── Auth Token ───
# Shared secret for /api/* routes (set a strong random string)
TRADING_TOKEN=

# ─── Server ───
PORT=3000

# ─── Telegram Alerts ───
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sync Token (PC <-> Phone state sync auth) ───
# Set a strong random string. If empty, default 'zeus-sync-2024' is used (INSECURE)
SYNC_TOKEN=

# ─── IP Whitelist (comma-separated, empty = allow all) ───
ALLOWED_IPS=
