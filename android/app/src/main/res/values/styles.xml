<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#0a0f16</item>
        <item name="colorPrimaryDark">#060a10</item>
        <item name="colorAccent">#f0c040</item>
        <item name="android:windowBackground">#0a0f16</item>
        <item name="android:navigationBarColor">#060a10</item>
        <item name="android:statusBarColor">#0a0f16</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:navigationBarColor">#060a10</item>
        <item name="android:statusBarColor">#0a0f16</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>
