<?xml version="1.0" encoding="utf-8"?>
<!-- [2026-06-24] ZEUS gaming widget (medium) — neon BTC + balance/PnL, circuit backdrop. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_circuit"
        android:scaleType="fitXY"
        android:alpha="0.5"
        android:contentDescription="circuit" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ ZEUS · BTC"
                android:textColor="#00ff88"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#aa00ff88"
                android:shadowDx="0" android:shadowDy="0" android:shadowRadius="7"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/wLiveDemo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_pill_live"
                android:text="LIVE"
                android:textColor="#00ff88"
                android:textSize="8sp"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/wStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text=""
                android:textColor="#ff3b6b"
                android:textSize="8sp"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/wRefresh"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="6dp"
                android:src="@android:drawable/ic_popup_sync"
                android:alpha="0.5"
                android:contentDescription="refresh" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/wBtc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="14sp"
                android:autoSizeMaxTextSize="26sp" />

            <TextView
                android:id="@+id/wBtcChg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="3dp"
                android:text="—"
                android:textColor="#aab8c8"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/widget_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BALANCE" android:textColor="#ff49b0" android:textSize="8sp"
                    android:textStyle="bold" android:letterSpacing="0.08" android:maxLines="1" />
                <TextView android:id="@+id/wBalance"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#eaf2ff" android:textSize="14sp"
                    android:textStyle="bold" android:maxLines="1" android:ellipsize="end"
                    android:autoSizeTextType="uniform" android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PnL TODAY" android:textColor="#ff49b0" android:textSize="8sp"
                    android:textStyle="bold" android:letterSpacing="0.08" android:maxLines="1" />
                <TextView android:id="@+id/wPnl"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#aab8c8" android:textSize="14sp"
                    android:textStyle="bold" android:maxLines="1" android:ellipsize="end"
                    android:autoSizeTextType="uniform" android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/wPositions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="0 pos"
                android:textColor="#aab8c8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/wAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AT OFF"
                android:textColor="#556677"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
