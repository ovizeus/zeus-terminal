<?xml version="1.0" encoding="utf-8"?>
<!-- [2026-06-24] ZEUS gaming widget (large) — RemoteViews-safe: plain LinearLayout root
     + gradient bg (no FrameLayout / no vector ImageView, which silently fail to inflate
     in app-widget RemoteViews on many launchers). Neon prices + live data. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="13dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ ZEUS"
            android:textColor="#00ff88"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/wLiveDemo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_pill_live"
            android:text="LIVE"
            android:textColor="#00ff88"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:maxLines="1" />

        <TextView
            android:id="@+id/wStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text=""
            android:textColor="#ff3b6b"
            android:textSize="9sp"
            android:maxLines="1" />

        <ImageView
            android:id="@+id/wRefresh"
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:layout_marginStart="7dp"
            android:src="@android:drawable/ic_popup_sync"
            android:alpha="0.5"
            android:contentDescription="refresh" />
    </LinearLayout>

    <!-- PRICES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View android:layout_width="3dp" android:layout_height="15dp"
            android:layout_marginEnd="7dp" android:background="#f0b90b" />
        <TextView android:layout_width="30dp" android:layout_height="wrap_content"
            android:text="BTC" android:textColor="#f0b90b" android:textSize="10sp"
            android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/wBtc"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="—" android:textColor="#ffffff"
            android:textSize="18sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end" android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="12sp" android:autoSizeMaxTextSize="20sp" />
        <TextView android:id="@+id/wBtcChg"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="6dp" android:text="—" android:textColor="#aab8c8"
            android:textSize="12sp" android:textStyle="bold" android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View android:layout_width="3dp" android:layout_height="15dp"
            android:layout_marginEnd="7dp" android:background="#6cb0ff" />
        <TextView android:layout_width="30dp" android:layout_height="wrap_content"
            android:text="ETH" android:textColor="#6cb0ff" android:textSize="10sp"
            android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/wEth"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="—" android:textColor="#ffffff"
            android:textSize="18sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end" android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="12sp" android:autoSizeMaxTextSize="20sp" />
        <TextView android:id="@+id/wEthChg"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="6dp" android:text="—" android:textColor="#aab8c8"
            android:textSize="12sp" android:textStyle="bold" android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View android:layout_width="3dp" android:layout_height="15dp"
            android:layout_marginEnd="7dp" android:background="#00ffa3" />
        <TextView android:layout_width="30dp" android:layout_height="wrap_content"
            android:text="SOL" android:textColor="#00ffa3" android:textSize="10sp"
            android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/wSol"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="—" android:textColor="#ffffff"
            android:textSize="18sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end" android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="12sp" android:autoSizeMaxTextSize="20sp" />
        <TextView android:id="@+id/wSolChg"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="6dp" android:text="—" android:textColor="#aab8c8"
            android:textSize="12sp" android:textStyle="bold" android:maxLines="1" />
    </LinearLayout>

    <!-- 24h H/L (BTC) + TOP MOVER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/wBtcHL"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="24h  H —  L —"
            android:textColor="#7d8a9a"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/wTopMover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="🔥 —"
            android:textColor="#00ff88"
            android:textSize="10sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/widget_divider" />

    <!-- STATS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BALANCE" android:textColor="#ff49b0" android:textSize="8sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:id="@+id/wBalance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="#eaf2ff" android:textSize="15sp"
                android:textStyle="bold" android:maxLines="1" android:ellipsize="end"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="10sp"
                android:autoSizeMaxTextSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PnL TODAY" android:textColor="#ff49b0" android:textSize="8sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:id="@+id/wPnl"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="#aab8c8" android:textSize="15sp"
                android:textStyle="bold" android:maxLines="1" android:ellipsize="end"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="10sp"
                android:autoSizeMaxTextSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.7" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="OPEN" android:textColor="#ff49b0" android:textSize="8sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:id="@+id/wPositions"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="0" android:textColor="#eaf2ff" android:textSize="15sp"
                android:textStyle="bold" android:maxLines="1" android:ellipsize="end"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="10sp"
                android:autoSizeMaxTextSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- FOOTER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/wAt"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="10dp" android:text="AT OFF" android:textColor="#556677"
            android:textSize="11sp" android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/wBrain"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Brain —" android:textColor="#00e5ff"
            android:textSize="11sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
